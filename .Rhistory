res <- read.csv("results.csv", header = TRUE)
res <- res %>% rename(gene_id = X)
View(res)
colnames(res)[colnames(res) == "X"] <- "gene_id"
library(dplyr)
df_merged <- left_join(exp_count_rounded, res, by = "gene_id")
df_sig <- df_merged[!is.na(df_merged$padj) & df_merged$padj < 0.05, ]
#####Downregulated
df_neg <- df_sig %>% filter(log2FoldChange < 2)
# select columns
count_matrix_neg <- df_neg[, c("X7wpc2p", "X7wpc3p", "X7wpc4p", "X15wpc27p", "X15wpc28p", "X15wpc29p")]
# names as row
rownames(count_matrix_neg) <- df_neg$gene_id
count_matrix_log_neg <- log2(count_matrix_neg + 1)
library(pheatmap)
dev.off()
pheatmap(count_matrix_log_neg,
scale = "row",
cluster_rows =  FALSE,
show_rownames = TRUE,
show_colnames = TRUE,
color = colorRampPalette(c("deepskyblue4", "white", "firebrick3"))(50),
main = "Downregulated")
#####Upregulated
df_pos <- df_sig %>% filter(log2FoldChange > 2)
# Seleccionar columnas
count_matrix_pos <- df_pos[, c("X7wpc2p", "X7wpc3p", "X7wpc4p", "X15wpc27p", "X15wpc28p", "X15wpc29p")]
# names as row
rownames(count_matrix_pos) <- df_pos$gene_id
count_matrix_log_pos <- log2(count_matrix_pos + 1)
library(pheatmap)
dev.off()
pheatmap(count_matrix_log_pos,
scale = "row",
cluster_rows = FALSE,
show_rownames = TRUE,
show_colnames = TRUE,
color = colorRampPalette(c("firebrick", "white", "darkgreen"))(50),
main = "Upregulated")
# Top N-Down of DEGs
topN_neg <- df_neg %>%
arrange(padj) %>%
slice(1:40)
find(rename)
find("rename")
