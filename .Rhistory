library(DESeq2)
library(ggplot2)
library(dplyr)
library(pheatmap)
library(apeglm)
library(ashr)
#cargar datos y ajustar formato
setwd("/Users/andreaz/transcriptomica/")
exp_count <- read.table("gene_counts_full_col.txt", header = TRUE, row.names = 1, sep = "\t")
rownames(exp_count) <- gsub("^gene-", "", rownames(exp_count))
feno <- read.table("metadata.csv", header = TRUE, sep = ",")
colDataExp <- data.frame(feno)
row.names(colDataExp) <- c(colnames(exp_count))
colDataExp
exp_count <- round(exp_count)
dds <- DESeqDataSetFromMatrix(countData = exp_count,
colData = colDataExp,
design = ~ condition)
# Filtrar
keep <- rowSums(counts(dds)) >= 10
dds <- dds[keep,]
# Definir factores
dds$condition <- relevel(dds$condition, ref = "7w")
# Correr DESeq
dds <- DESeq(dds)
# Valor de significancia
res <- results(dds, alpha = 0.05)
res
summary(res)
resultsNames(dds)
# save
write.csv(as.data.frame(res), "results.csv", row.names = TRUE)
# normalization and save
normalized_counts <- counts(dds, normalized=TRUE)
write.csv(as.data.frame(normalized_counts), "results_norm.tsv", row.names = TRUE)
