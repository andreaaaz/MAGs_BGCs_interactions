legendLabSize = 14,
pCutoff = 0.05,
FCcutoff = 2,
axisLabSize = 15,
pointSize = 4,
labSize = 6,
cutoffLineCol = "black",
cutoffLineWidth = 0.4,
gridlines.major = FALSE,
gridlines.minor = FALSE,
col = c("grey50", "green", "blue", "red")) +
